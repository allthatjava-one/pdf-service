{
  "name": "pdf-service",
  "main": "src/index.py",
  "compatibility_date": "2024-12-18",
  "compatibility_flags": ["python_workers"],
  "r2_buckets": [
    {
      "binding": "R2_BUCKET",
      "bucket_name": "pdf-compressor"
    }
  ],
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  }
}